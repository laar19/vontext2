<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Shadow underneath the document sheet -->
    <path
        android:pathData="M38,30 h30 l12,12 v38 c0,4.4 -3.6,8 -8,8 h-34 c-4.4,0 -8,-3.6 -8,-8 v-42 c0,-4.4 3.6,-8 8,-8 z"
        android:fillColor="#15000000" />
        
    <!-- Document Page base (White card with crisp borders) -->
    <path
        android:pathData="M36,28 h30 l14,14 v38 c0,4.4 -3.6,8 -8,8 h-36 c-4.4,0 -8,-3.6 -8,-8 v-44 c0,-4.4 3.6,-8 8,-8 z"
        android:fillColor="#FFFFFF" />
        
    <!-- Folded corner of the document -->
    <path
        android:pathData="M66,28 v14 h14 z"
        android:fillColor="#E0E6F8" />

    <!-- Text line indicators inside the document page -->
    <path
        android:pathData="M34,48 h30"
        android:strokeWidth="3.5"
        android:strokeColor="#B0C1EE"
        android:strokeLineCap="round" />
    <path
        android:pathData="M34,56 h38"
        android:strokeWidth="3.5"
        android:strokeColor="#B0C1EE"
        android:strokeLineCap="round" />
    <path
        android:pathData="M34,64 h24"
        android:strokeWidth="3.5"
        android:strokeColor="#B0C1EE"
        android:strokeLineCap="round" />

    <!-- PDF letters indicator styled inside the page footer -->
    <path
        android:pathData="M52,73 h14"
        android:strokeWidth="4"
        android:strokeColor="#3F51B5"
        android:strokeLineCap="round" />

    <!-- Overlapping Play button triangle (Gradient filled indigo) -->
    <path
        android:pathData="M58,40 L78,54 L58,68 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="58"
                android:startY="40"
                android:endX="78"
                android:endY="68"
                android:type="linear">
                <item android:offset="0.0" android:color="#4E6BF2" />
                <item android:offset="1.0" android:color="#3B50C1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
